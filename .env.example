# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose defaults):
DATABASE_URL=postgresql://vivauser:vivapass@localhost:5432/vivavoce

# Production (Railway / Render / Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change to a strong random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Password used to log into /admin
ADMIN_PASSWORD=admin123

# ─── AI — Groq (Free, no credit card required) ────────────────────────────────
# Sign up at https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Optional: restrict CORS to your frontend domain in production
# CORS_ORIGIN=https://yourdomain.com
